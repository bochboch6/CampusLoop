# Copier ce fichier en .env et renseigner les valeurs
# Les variables EXPO_PUBLIC_ sont exposées au client (bundle JS)

# URL du backend FastAPI
# - Emulateur Android : http://10.0.2.2:8000
# - Simulateur iOS / device physique sur le même réseau : http://<IP_LAN>:8000
# - Production : https://api.votre-domaine.com
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
